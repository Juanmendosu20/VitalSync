# mock: demo offline local sin backend
# supabase: inserta directo en pacientes_dim/vitales para conectar con dashboard
# edge: usa la Edge Function ingest-vitals cuando exista
EXPO_PUBLIC_SYNC_MODE=supabase

# Compatibilidad con el primer prototipo. Si usas EXPO_PUBLIC_SYNC_MODE, puedes ignorarla.
EXPO_PUBLIC_USE_MOCK_SYNC=false

EXPO_PUBLIC_INGEST_VITALS_URL=https://your-project-ref.functions.supabase.co/ingest-vitals

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_HOSPITAL_ID=HSV-001
EXPO_PUBLIC_PATIENT_HASH_SALT=vitalsync-demo-salt

# Opcional: si se omite, la app usa <SUPABASE_URL>/functions/v1/sms-alert.
EXPO_PUBLIC_SMS_ALERT_URL=https://your-project-ref.functions.supabase.co/sms-alert

# Inserta un resumen en his_queue para que el Circuit Breaker/HIS del dashboard lo vea.
EXPO_PUBLIC_ENABLE_HIS_QUEUE=true

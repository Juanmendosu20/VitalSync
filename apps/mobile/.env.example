# mock: demo offline local sin backend
# supabase: inserta directo en pacientes_dim/vitales para conectar con dashboard
# edge: usa la Edge Function ingest-vitals cuando exista
EXPO_PUBLIC_SYNC_MODE=mock

# Compatibilidad con el primer prototipo. Si usas EXPO_PUBLIC_SYNC_MODE, puedes ignorarla.
EXPO_PUBLIC_USE_MOCK_SYNC=true

EXPO_PUBLIC_INGEST_VITALS_URL=https://your-project-ref.functions.supabase.co/ingest-vitals

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_HOSPITAL_ID=HSP-SAN-VICENTE
EXPO_PUBLIC_PATIENT_HASH_SALT=vitalsync-demo-salt
